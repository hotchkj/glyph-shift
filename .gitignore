# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.out
coverage.html
*.coverprofile
profile.cov

# quality gate artifacts
mutations.json

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# GoReleaser output (binaries, archives, checksums)
dist/

# Temporary clones of external actions (do not commit)
.tmp-action-semantic-pr/
.tmp-github-tag-action/

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Local Serena workspace state
.serena/

# CodeGraph MCP local workspace data (see .codegraph/.gitignore)
.codegraph/*
!.codegraph/.gitignore
